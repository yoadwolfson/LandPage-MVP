<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ app.app_name }}</title>
  <style>
    :root {
      --primary: {{ style.get('color_primary', '#2563EB') }};
      --secondary: {{ style.get('color_secondary', '#334155') }};
      --bg: {{ style.get('color_background', '#F8FAFC') }};
      --surface: {{ style.get('color_surface', '#FFFFFF') }};
      --text: {{ style.get('color_text', '#0F172A') }};
      --accent: {{ style.get('color_accent', '#F59E0B') }};
    }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: "Segoe UI", Arial, sans-serif; color: var(--text); background: var(--bg); }
    .container { max-width: 1040px; margin: 0 auto; padding: 24px; }
    .layout { display: grid; gap: 14px; grid-template-columns: 2fr 1fr; }
    .card {
      border-radius: 14px;
      border: 1px solid color-mix(in srgb, var(--secondary) 14%, transparent);
      background: var(--surface);
      padding: 16px;
    }
    h1 { margin: 8px 0 8px; font-size: 35px; }
    p { margin: 0; color: color-mix(in srgb, var(--text) 84%, transparent); }
    .cta {
      display: inline-block;
      margin-top: 12px;
      text-decoration: none;
      color: #fff;
      background: var(--primary);
      border-radius: 10px;
      padding: 11px 17px;
      font-weight: 700;
    }
    .checklist { margin: 0; padding-left: 18px; }
    .checklist li { margin: 6px 0; }
    .mini { font-size: 13px; color: color-mix(in srgb, var(--text) 66%, transparent); }
    .review { border-left: 3px solid var(--accent); padding-left: 10px; margin-bottom: 10px; }
    .faq article { margin-bottom: 10px; }
    @media (max-width: 900px) {
      .layout { grid-template-columns: 1fr; }
      h1 { font-size: 30px; }
    }
  </style>
</head>
<body>
  <main class="container">
    <section class="layout">
      <article class="card">
        <div class="mini">{{ style.get('template_id', 'productivity')|upper }} TEMPLATE</div>
        <h1>{{ content.hero_headline }}</h1>
        <p>{{ content.hero_subheadline }}</p>
        <a class="cta" href="{{ content.cta_url }}">{{ content.cta_text }}</a>
      </article>
      <article class="card">
        <strong>Quick Facts</strong>
        <ul class="checklist">
          <li>Bucket: {{ style.get('bucket', 'default') }}</li>
          <li>Rating: {% if content.social_proof_rating %}{{ '%.2f'|format(content.social_proof_rating) }}{% else %}N/A{% endif %}</li>
          <li>Installs: {{ content.social_proof_installs or 'N/A' }}</li>
        </ul>
      </article>
    </section>

    <section class="card" style="margin-top:14px;">
      <h2>Core Benefits</h2>
      <ul class="checklist">
        {% for b in content.benefits %}
        <li><strong>{{ b.title }}:</strong> {{ b.description }}</li>
        {% endfor %}
      </ul>
    </section>

    <section class="layout" style="margin-top:14px;">
      <article class="card">
        <h2>{{ content.social_proof_headline }}</h2>
        {% for r in content.social_proof_reviews %}
        <blockquote class="review">
          <strong>{{ r.rating }}/5</strong>
          <div>{{ r.text }}</div>
          <footer class="mini">- {{ r.reviewer }}</footer>
        </blockquote>
        {% endfor %}
      </article>

      <article class="card faq">
        <h2>FAQ</h2>
        {% for f in content.faq_items %}
        <article>
          <strong>{{ f.question }}</strong>
          <div>{{ f.answer }}</div>
        </article>
        {% endfor %}
      </article>
    </section>
  </main>
</body>
</html>

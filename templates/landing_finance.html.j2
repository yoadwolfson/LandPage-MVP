<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ app.app_name }}</title>
  <style>
    :root {
      --primary: {{ style.get('color_primary', '#0EA5E9') }};
      --secondary: {{ style.get('color_secondary', '#1E293B') }};
      --bg: {{ style.get('color_background', '#F8FAFC') }};
      --surface: {{ style.get('color_surface', '#FFFFFF') }};
      --text: {{ style.get('color_text', '#0F172A') }};
      --accent: {{ style.get('color_accent', '#10B981') }};
    }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: "Segoe UI", Arial, sans-serif; color: var(--text); background: var(--bg); }
    .container { max-width: 1100px; margin: 0 auto; padding: 24px; }
    .hero {
      border-radius: 16px;
      border: 1px solid color-mix(in srgb, var(--secondary) 14%, transparent);
      background: linear-gradient(160deg, #fff, color-mix(in srgb, var(--bg) 92%, var(--primary)));
      padding: 22px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 14px;
      align-items: center;
    }
    h1 { margin: 6px 0 10px; font-size: 36px; }
    p { margin: 0; color: color-mix(in srgb, var(--text) 80%, transparent); }
    .kpi-grid { margin-top: 12px; display: grid; gap: 10px; grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .kpi {
      border-radius: 12px;
      border: 1px solid color-mix(in srgb, var(--secondary) 14%, transparent);
      background: var(--surface);
      padding: 10px;
    }
    .kpi .label { font-size: 12px; color: color-mix(in srgb, var(--text) 62%, transparent); }
    .kpi .value { font-size: 20px; font-weight: 700; }
    .cta {
      display: inline-block;
      margin-top: 12px;
      text-decoration: none;
      color: #fff;
      font-weight: 700;
      background: linear-gradient(90deg, var(--primary), color-mix(in srgb, var(--accent) 35%, var(--primary)));
      border-radius: 10px;
      padding: 12px 18px;
    }
    .section {
      margin-top: 14px;
      border-radius: 14px;
      border: 1px solid color-mix(in srgb, var(--secondary) 14%, transparent);
      background: var(--surface);
      padding: 16px;
    }
    .benefits { display: grid; gap: 10px; grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .benefit { border-radius: 10px; padding: 12px; background: color-mix(in srgb, var(--bg) 80%, var(--accent)); }
    .review { border-left: 3px solid var(--accent); border-radius: 8px; padding: 10px; background: color-mix(in srgb, var(--bg) 74%, #fff); }
    .meta { color: color-mix(in srgb, var(--text) 65%, transparent); font-size: 13px; }
    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; }
      .kpi-grid, .benefits { grid-template-columns: 1fr; }
      h1 { font-size: 31px; }
    }
  </style>
</head>
<body>
  <main class="container">
    <section class="hero">
      <div>
        <div class="meta">{{ style.get('template_objective', 'Trust-first conversion') }}</div>
        <h1>{{ content.hero_headline }}</h1>
        <p>{{ content.hero_subheadline }}</p>
        <a class="cta" href="{{ content.cta_url }}">{{ content.cta_text }}</a>
      </div>
      <img src="{{ content.hero_image_url }}" alt="{{ app.app_name }} icon" style="width: 104px; height: 104px; border-radius: 20px;" />
    </section>

    <section class="kpi-grid">
      <article class="kpi">
        <div class="label">CATEGORY</div>
        <div class="value">{{ style.get('bucket', 'default')|upper }}</div>
      </article>
      <article class="kpi">
        <div class="label">RATING</div>
        <div class="value">{% if content.social_proof_rating %}{{ '%.2f'|format(content.social_proof_rating) }}{% else %}N/A{% endif %}</div>
      </article>
      <article class="kpi">
        <div class="label">INSTALLS</div>
        <div class="value">{{ content.social_proof_installs or 'N/A' }}</div>
      </article>
    </section>

    <section class="section">
      <h2>Why Users Choose It</h2>
      <div class="benefits">
        {% for b in content.benefits %}
        <article class="benefit">
          <strong>{{ b.title }}</strong>
          <div>{{ b.description }}</div>
        </article>
        {% endfor %}
      </div>
    </section>

    <section class="section">
      <h2>{{ content.social_proof_headline }}</h2>
      {% for r in content.social_proof_reviews %}
      <blockquote class="review">
        <strong>{{ r.rating }}/5</strong>
        <div>{{ r.text }}</div>
        <footer class="meta">- {{ r.reviewer }}</footer>
      </blockquote>
      {% endfor %}
    </section>

    <section class="section">
      <h2>Frequently Asked Questions</h2>
      {% for f in content.faq_items %}
      <article style="margin-bottom:10px;">
        <strong>{{ f.question }}</strong>
        <div>{{ f.answer }}</div>
      </article>
      {% endfor %}
    </section>
  </main>
</body>
</html>

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ app.app_name }}</title>
  <style>
    {% set hero_layout = style.get('hero_layout', 'split') %}
    {% set card_layout = style.get('card_layout', 'grid') %}
    {% set typography_density = style.get('typography_density', 'normal') %}
    {% set section_order = style.get('section_order', 'proof-first') %}
    {% set visual_intensity = style.get('visual_intensity', 'medium') %}
    
    :root {
      --primary: {{ style.get('color_primary', '#0EA5E9') }};
      --secondary: {{ style.get('color_secondary', '#1E293B') }};
      --bg: {{ style.get('color_background', '#F8FAFC') }};
      --surface: {{ style.get('color_surface', '#FFFFFF') }};
      --text: {{ style.get('color_text', '#0F172A') }};
      --accent: {{ style.get('color_accent', '#10B981') }};
      {% if typography_density == 'compact' %}
      --h1-size: 28px;
      --h2-size: 22px;
      --padding: 12px;
      --section-margin: 10px;
      {% elif typography_density == 'spacious' %}
      --h1-size: 44px;
      --h2-size: 28px;
      --padding: 24px;
      --section-margin: 18px;
      {% else %}
      --h1-size: 36px;
      --h2-size: 24px;
      --padding: 16px;
      --section-margin: 14px;
      {% endif %}
    }
    * { box-sizing: border-box; }
    body { margin: 0; font-family: "Segoe UI", Arial, sans-serif; color: var(--text); background: var(--bg); }
    .container { max-width: 1100px; margin: 0 auto; padding: 24px; }
    .flow { display: flex; flex-direction: column; }
    .hero {
      border-radius: 16px;
      border: 1px solid color-mix(in srgb, var(--secondary) 14%, transparent);
      background: linear-gradient(160deg, #fff, color-mix(in srgb, var(--bg) 92%, var(--primary)));
      padding: var(--padding);
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 16px;
      align-items: flex-start;
      {% if visual_intensity == 'high' %}
      box-shadow: 0 14px 30px rgba(15, 23, 42, 0.16);
      {% elif visual_intensity == 'low' %}
      box-shadow: 0 6px 16px rgba(15, 23, 42, 0.07);
      {% else %}
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.11);
      {% endif %}
    }
    h1 { margin: 6px 0 10px; font-size: var(--h1-size); }
    h2 { font-size: var(--h2-size); }
    p { margin: 0; color: color-mix(in srgb, var(--text) 80%, transparent); }
    .kpi-grid { margin-top: 12px; display: grid; gap: 10px; grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .kpi {
      border-radius: 12px;
      border: 1px solid color-mix(in srgb, var(--secondary) 14%, transparent);
      background: var(--surface);
      padding: var(--padding);
    }
    .kpi .label { font-size: 12px; color: color-mix(in srgb, var(--text) 62%, transparent); }
    .kpi .value { font-size: 20px; font-weight: 700; }
    .kpi-list { margin: 0; padding-left: 18px; }
    .kpi-list li { margin: 6px 0; font-size: 14px; line-height: 1.35; }
    .why-list { margin: 0; padding-left: 18px; }
    .why-list li { margin: 8px 0; line-height: 1.4; }
    .cta {
      display: inline-block;
      margin-top: 12px;
      text-decoration: none;
      color: #fff;
      font-weight: 700;
      background: linear-gradient(90deg, var(--primary), color-mix(in srgb, var(--accent) 35%, var(--primary)));
      border-radius: 10px;
      padding: 12px 18px;
    }
    .section {
      margin-top: var(--section-margin);
      border-radius: 14px;
      border: 1px solid color-mix(in srgb, var(--secondary) 14%, transparent);
      background: var(--surface);
      padding: var(--padding);
    }
    {% if card_layout == 'list' %}
    .benefits { display: grid; gap: 10px; grid-template-columns: 1fr; }
    {% else %}
    .benefits { display: grid; gap: 10px; grid-template-columns: repeat(2, minmax(0, 1fr)); }
    {% endif %}
    .benefit { border-radius: 10px; padding: var(--padding); background: color-mix(in srgb, var(--bg) 80%, var(--accent)); }
    .review { border-left: 3px solid var(--accent); border-radius: 8px; padding: var(--padding); background: color-mix(in srgb, var(--bg) 74%, #fff); }
    .meta { color: color-mix(in srgb, var(--text) 65%, transparent); font-size: 13px; }
    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; }
      .kpi-grid, .benefits { grid-template-columns: 1fr; }
      h1 { font-size: 31px; }
    }
  </style>
</head>
<body>
  <main class="container">
    <section class="hero">
      <div>
        <div class="meta">Made by {{ app.developer_name or app.app_name }}</div>
        <h1>{{ content.hero_headline }}</h1>
        <p>{{ content.hero_subheadline }}</p>
        <a class="cta" href="{{ content.cta_url }}">{{ content.cta_text }}</a>
      </div>
      <img src="{{ content.hero_image_url }}" alt="{{ app.app_name }} icon" style="width: 104px; height: 104px; border-radius: 20px;" />
    </section>

    <div class="flow">
    <section class="kpi-grid" style="order:1;">
      <article class="kpi">
        <div class="label">CATEGORY</div>
        <div class="value">{{ style.get('bucket', 'default')|upper }}</div>
      </article>
      {% if content.social_proof_rating %}
      <article class="kpi">
        <div class="label">RATING</div>
        <div class="value">{{ '%.2f'|format(content.social_proof_rating) }}</div>
      </article>
      {% endif %}
      {% if content.social_proof_installs %}
      <article class="kpi">
        <div class="label">INSTALLS</div>
        <div class="value">{{ content.social_proof_installs }}</div>
      </article>
      {% endif %}
    </section>

    <section class="section" style="order:{% if section_order == 'proof-first' %}3{% else %}2{% endif %};">
      <h2>Why Install</h2>
      {% if content.benefits %}
      <ul class="why-list">
        {% for b in content.benefits[:3] %}
        <li><strong>{{ b.title }}</strong></li>
        {% endfor %}
      </ul>
      {% else %}
      <p>Built for practical day-to-day money management.</p>
      {% endif %}
    </section>

    <section class="section" style="order:{% if section_order == 'proof-first' %}4{% else %}3{% endif %};">
      <h2>Why Users Choose It</h2>
      <div class="benefits">
        {% for b in content.benefits %}
        <article class="benefit">
          <strong>{{ b.title }}</strong>
          <div>{{ b.description }}</div>
        </article>
        {% endfor %}
      </div>
    </section>

    {% if content.screenshots %}
    <section class="section" style="order:{% if section_order == 'visual-first' %}2{% elif section_order == 'proof-first' %}5{% else %}4{% endif %};">
      <h2>Screenshots</h2>
      <div class="benefits" style="grid-template-columns: repeat(3, minmax(0, 1fr));">
        {% for s in content.screenshots[:6] %}
        <img src="{{ s }}" alt="app screenshot" style="width:100%; border-radius:12px; border:1px solid color-mix(in srgb, var(--secondary) 14%, transparent);" />
        {% endfor %}
      </div>
    </section>
    {% endif %}

    <section class="section" style="order:{% if section_order == 'proof-first' %}2{% else %}5{% endif %};">
      <h2>{{ content.social_proof_headline }}</h2>
      {% if content.social_proof_reviews %}
      {% for r in content.social_proof_reviews %}
      <blockquote class="review">
        <strong>{{ r.rating }}/5</strong>
        <div>{{ r.text }}</div>
        <footer class="meta">- {{ r.reviewer }}</footer>
      </blockquote>
      {% endfor %}
      {% else %}
      <p class="meta">{{ strategy.main_angle }}</p>
      {% endif %}
    </section>

    <section class="section" style="order:6;">
      <h2>Frequently Asked Questions</h2>
      {% for f in content.faq_items %}
      <article style="margin-bottom:10px;">
        <strong>{{ f.question }}</strong>
        <div>{{ f.answer }}</div>
      </article>
      {% endfor %}
    </section>
    </div>
  </main>
</body>
</html>

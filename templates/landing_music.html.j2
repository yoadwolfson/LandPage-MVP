<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ app.app_name }}</title>
  <style>
    {% set hero_layout = style.get('hero_layout', 'split') %}
    {% set card_layout = style.get('card_layout', 'carousel') %}
    {% set typography_density = style.get('typography_density', 'spacious') %}
    {% set section_order = style.get('section_order', 'visual-first') %}
    {% set visual_intensity = style.get('visual_intensity', 'high') %}
    
    :root {
      --primary: {{ style.get('color_primary', '#1DB954') }};
      --secondary: {{ style.get('color_secondary', '#0B1320') }};
      --bg: {{ style.get('color_background', '#070A0F') }};
      --surface: {{ style.get('color_surface', '#111827') }};
      --text: {{ style.get('color_text', '#F3F4F6') }};
      --accent: {{ style.get('color_accent', '#8B5CF6') }};
      {% if typography_density == 'compact' %}
      --h1-size: 32px;
      --h2-size: 20px;
      --spacing: 10px;
      {% elif typography_density == 'spacious' %}
      --h1-size: 48px;
      --h2-size: 28px;
      --spacing: 20px;
      {% else %}
      --h1-size: 40px;
      --h2-size: 24px;
      --spacing: 16px;
      {% endif %}
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      color: var(--text);
      background:
        radial-gradient(900px 500px at 8% -10%, color-mix(in srgb, var(--primary) 20%, transparent), transparent),
        radial-gradient(800px 500px at 95% 0%, color-mix(in srgb, var(--accent) 16%, transparent), transparent),
        var(--bg);
      font-family: "Segoe UI", Arial, sans-serif;
    }
    .container { max-width: 1120px; margin: 0 auto; padding: 24px; }
    .flow { display: flex; flex-direction: column; }
    .hero {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: var(--spacing);
      align-items: flex-start;
      border: 1px solid color-mix(in srgb, var(--text) 12%, transparent);
      border-radius: 18px;
      background: linear-gradient(145deg, color-mix(in srgb, var(--surface) 92%, var(--secondary)), color-mix(in srgb, var(--surface) 70%, var(--primary)));
      padding: 24px;
      {% if visual_intensity == 'high' %}
      box-shadow: 0 16px 34px rgba(0, 0, 0, 0.38);
      {% elif visual_intensity == 'low' %}
      box-shadow: 0 7px 18px rgba(0, 0, 0, 0.22);
      {% else %}
      box-shadow: 0 11px 26px rgba(0, 0, 0, 0.30);
      {% endif %}
    }
    h1 { margin: 8px 0 10px; font-size: var(--h1-size); line-height: 1.06; }
    h2 { font-size: var(--h2-size); }
    p { margin: 0; color: color-mix(in srgb, var(--text) 84%, transparent); }
    .meta { font-size: 13px; color: color-mix(in srgb, var(--text) 65%, transparent); margin-top: 10px; }
    .cta {
      display: inline-block;
      margin-top: var(--spacing);
      padding: 12px 20px;
      border-radius: 999px;
      text-decoration: none;
      color: #04100a;
      background: linear-gradient(90deg, var(--primary), color-mix(in srgb, var(--accent) 38%, #fff));
      font-weight: 700;
    }
    .shot-strip {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--spacing);
      margin-top: var(--spacing);
    }
    .shot-strip img { width: 100%; border-radius: 10px; border: 1px solid color-mix(in srgb, var(--text) 20%, transparent); }
    .proof, .benefits, .faq {
      margin-top: var(--spacing);
      border-radius: 14px;
      border: 1px solid color-mix(in srgb, var(--text) 12%, transparent);
      background: color-mix(in srgb, var(--surface) 86%, var(--secondary));
      padding: 16px;
    }
    {% if card_layout == 'list' %}
    .grid { display: grid; gap: var(--spacing); grid-template-columns: 1fr; }
    {% elif card_layout == 'carousel' %}
    .grid { display: grid; gap: var(--spacing); grid-template-columns: 1fr; overflow-x: auto; }
    {% else %}
    .grid { display: grid; gap: var(--spacing); grid-template-columns: repeat(3, minmax(0, 1fr)); }
    {% endif %}
    .benefit { border-radius: 12px; padding: 12px; background: color-mix(in srgb, var(--surface) 88%, var(--accent)); }
    .review { border-radius: 10px; padding: 12px; border-left: 3px solid var(--primary); background: color-mix(in srgb, var(--surface) 76%, var(--secondary)); }
    .token {
      display: inline-block;
      font-size: 11px;
      font-weight: 700;
      margin-right: 6px;
      padding: 4px 8px;
      border-radius: 999px;
      background: var(--text);
      color: var(--surface);
      border: 1px solid color-mix(in srgb, var(--text) 35%, transparent);
    }
    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; }
      .grid { grid-template-columns: 1fr; }
      .shot-strip { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      h1 { font-size: 32px; }
    }
  </style>
</head>
<body>
  <main class="container">
    <section class="hero">
      <div>
        <div class="token">{{ style.get('template_id', 'music')|upper }}</div>
        <h1>{{ content.hero_headline }}</h1>
        <p>{{ content.hero_subheadline }}</p>
        <div class="meta">
          {% if content.social_proof_rating %}Rating {{ '%.2f'|format(content.social_proof_rating) }}{% endif %}
          {% if content.social_proof_installs %} • {{ content.social_proof_installs }} installs{% endif %}
        </div>
        <a class="cta" href="{{ content.cta_url }}">{{ content.cta_text }}</a>
      </div>
      <div>
        <img src="{{ content.hero_image_url }}" alt="{{ app.app_name }} icon" style="width: 112px; height: 112px; border-radius: 18px;" />
        {% if content.screenshots %}
        <div class="shot-strip">
          {% for s in content.screenshots[:3] %}
          <img src="{{ s }}" alt="app screenshot" />
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </section>

    <div class="flow">
    <section class="benefits" style="order:{% if section_order == 'proof-first' %}2{% elif section_order == 'cta-last' %}3{% else %}3{% endif %};">
      <h2>Top Reasons To Install</h2>
      <div class="grid">
        {% for b in content.benefits %}
        <article class="benefit">
          <div class="token">{{ b.icon_emoji }}</div>
          <h3>{{ b.title }}</h3>
          <p>{{ b.description }}</p>
        </article>
        {% endfor %}
      </div>
    </section>

    <section class="proof" style="order:{% if section_order == 'proof-first' %}1{% else %}2{% endif %};">
      <h2>{{ content.social_proof_headline }}</h2>
      <div class="grid">
        {% for r in content.social_proof_reviews %}
        <blockquote class="review">
          <strong>{{ r.rating }}/5</strong>
          <div>{{ r.text }}</div>
          <footer class="meta">- {{ r.reviewer }}</footer>
        </blockquote>
        {% endfor %}
      </div>
    </section>

    <section class="faq" style="order:4;">
      <h2>FAQ</h2>
      {% for f in content.faq_items %}
      <article style="margin-bottom:10px;">
        <strong>{{ f.question }}</strong>
        <div>{{ f.answer }}</div>
      </article>
      {% endfor %}
    </section>
    </div>
  </main>
</body>
</html>
